# ── Build output ────────────────────────────────────────────────────────────
# bin/ holds the built .dll and .vsix; obj/ holds generated AssemblyInfo, the
# merged .vsixmanifest, NuGet assets, etc. Both are fully regenerated by a build.
[Bb]in/
[Oo]bj/

# ── Visual Studio / IDE ──────────────────────────────────────────────────────
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.vsp
*.vspx
*.psess
launchSettings.json

# Rider / VS Code (keep nothing IDE-local)
.idea/
*.DotSettings.user

# ── VSIX / build artifacts ───────────────────────────────────────────────────
*.vsix
*.binlog
*.log

# ── Test results ─────────────────────────────────────────────────────────────
[Tt]est[Rr]esults/
*.trx
*.coverage
*.cover=*

# ── NuGet ────────────────────────────────────────────────────────────────────
packages/
*.nupkg
*.snupkg
.nuget/

# ── OS cruft ─────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store

# ── Claude Code ──────────────────────────────────────────────────────────────
# Per-user local settings (permission allowlist etc.) — keep .claude/settings.json
# and .claude/commands shared, but never commit the local override.
.claude/settings.local.json

# ── Misc local scratch ───────────────────────────────────────────────────────
# Throwaway probe scripts used to verify CLI/MCP behavior locally.
probe*.js
